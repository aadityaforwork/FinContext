# ---- Auth ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-to-a-long-random-string

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Cookies ----
# Set COOKIE_SECURE=true in production (HTTPS only)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.yourdomain.com   # optional, for subdomain sharing

# ---- Frontend / CORS ----
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Google OAuth ----
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ---- App integrations (optional, pre-existing) ----
# GEMINI_API_KEY=
# KITE_API_KEY=
# KITE_API_SECRET=
